generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  name           String?
  username       String    @unique
  password       String
  age            Int?
  gender         String?
  email          String    @unique
  avatar         String?   // emoji avatar picked during onboarding
  birthday       DateTime?
  location       String?
  language       String?
  interests      String[]

  skills         String[]     // e.g. ["Node.js", "AI/ML"]

  madeTillFar    String?
  promptTagline  String?
  domain         String?
  personType         String?      // "student" | "professional" | "freelancer"
  role               String?      // e.g. "Frontend Developer", "Designer"
  experienceLevel    String?      // legacy text level (kept for backward compat)
  experience         Int?         // years of paid work
  practiceYears      Int?         // years including learning
  exploringInterests String[]    // alias for interests in old API — kept for backward compat
  findMeFor          String[]    // ["Leetcode partner", "Co-founder", "Matiks squad", ...]
  goals              String[]
  currentlyWorkingOn String?
  college            String?     // college/university name, e.g. "IIT Bombay"
  course             String?     // course/degree, e.g. "B.Tech"
  company            String?     // optional current company (typically for professionals)
  aspirantOf         String?     // exam/goal an Aspirant is preparing for, e.g. "UPSC", "GATE", "NEET PG"
  showcase           Json?       // array of { title, type, description, link } the user has built/done
  profileCompletedAt DateTime?   // set when the profile first becomes "complete" (discovery nudge tracking)
  onboardingComplete Boolean @default(false)

  swipeStreak        Int       @default(0)   // consecutive days with >= 1 swipe
  lastSwipeAt        DateTime?               // last time the user swiped (drives streak)

  // Last time the user did anything authenticated on the platform. Bumped
  // (throttled) by LastActiveInterceptor. Used by the email digest to SKIP
  // emailing users who are currently active.
  lastActiveAt       DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  posts          Post[]     @relation("UserPosts")
  comments       Comment[]  @relation("UserComments")
  votes          Vote[]
  swipesGiven    Swipe[]     @relation("SwipesGiven")
  swipesReceived Swipe[]     @relation("SwipesReceived")
  matchesAsUser1 Match[]     @relation("User1Matches")
  matchesAsUser2 Match[]     @relation("User2Matches")
  chats          Chat[]      @relation("ChatParticipants")
  chatReads      ChatRead[]  @relation("ChatReads")
  likesGiven     ProfileLike[] @relation("ProfileLikesGiven")
  likesReceived  ProfileLike[] @relation("ProfileLikesReceived")

  notifications   Notification[]   @relation("UserNotifications")
  emailDigestLogs EmailDigestLog[] @relation("UserEmailDigestLogs")
}

model ProfileLike {
  id           String   @id @default(uuid())
  likerId      String
  liker        User     @relation("ProfileLikesGiven", fields: [likerId], references: [id])
  likedUserId  String
  likedUser    User     @relation("ProfileLikesReceived", fields: [likedUserId], references: [id])
  itemKey      String   // e.g. "goal:Land a job at FAANG", "skill:React", "workingOn"
  createdAt    DateTime @default(now())

  @@unique([likerId, likedUserId, itemKey])
  @@index([likedUserId])
}


model Post {
  id             String     @id @default(uuid())
  title          String
  description    String
  type           PostType
  techstack      String
  authorId       String
  author         User       @relation("UserPosts", fields: [authorId], references: [id])
  contributorIds String[]
  allowJoinTeam  Boolean    @default(false)
  likes          Int        @default(0)
  badge          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  comments       Comment[]
  votes          Vote[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation("UserComments", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model Vote {
  id       String   @id @default(uuid())
  userId   String
  postId   String
  type     VoteType

  // 👇 Relations
  user     User     @relation(fields: [userId], references: [id])
  post     Post     @relation(fields: [postId], references: [id])
}

enum PostType {
  PRODUCT
  PROJECT
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}


model Swipe {
  id        String         @id @default(uuid())
  swiperId  String
  swiper    User           @relation("SwipesGiven", fields: [swiperId], references: [id])
  swipedId  String
  swiped    User           @relation("SwipesReceived", fields: [swipedId], references: [id])
  direction SwipeDirection
  intent    String?         // findMeFor value the swiper was looking for (e.g. "Co-founder")
  domain    String?         // optional domain/interest like AI, Web3
  filters   Json?           // advanced filters applied at swipe time: { personType?, location?, interest?, goal?, skill? }
  createdAt DateTime        @default(now())

  @@unique([swiperId, swipedId])
  @@index([swiperId, swipedId])
}

model Match {
  id         String       @id @default(uuid())
  user1Id    String
  user2Id    String
  user1      User         @relation("User1Matches", fields: [user1Id], references: [id])
  user2      User         @relation("User2Matches", fields: [user2Id], references: [id])
  intent     String?
  createdAt  DateTime     @default(now())
  chats      Chat[]       @relation("MatchChats")
  reads      ChatRead[]   @relation("MatchReads")

  @@unique([user1Id, user2Id])
}

model Chat {
  id         String     @id @default(uuid())
  matchId    String
  match     Match    @relation("MatchChats", fields: [matchId], references: [id])
  senderId  String
  sender     User       @relation("ChatParticipants", fields: [senderId], references: [id])
  message    String
  createdAt  DateTime   @default(now())
}

// Per-participant read marker for a match's chat. One row per (match, user);
// `lastReadAt` advances as the user views the conversation. Unread = messages
// from the other participant with createdAt > lastReadAt.
model ChatRead {
  id         String   @id @default(uuid())
  matchId    String
  match      Match    @relation("MatchReads", fields: [matchId], references: [id])
  userId     String
  user       User     @relation("ChatReads", fields: [userId], references: [id])
  lastReadAt DateTime @default(now())

  @@unique([matchId, userId])
  @@index([userId])
}

enum SwipeDirection {
  RIGHT
  LEFT
}

// A single in-app activity event for a recipient. Created at the moment the
// activity happens (best-effort, never blocks the triggering action). It powers
// both the in-app notifications surface and the 6-hourly email digest.
//
// Email-once guarantee: `emailedAt` is set ONLY after a digest containing this
// row is delivered successfully. The digest query filters `emailedAt IS NULL`,
// so a notification can never appear in two emails. `read = true` rows are also
// excluded (user already saw it in-app → don't email about it).
model Notification {
  id        String           @id @default(uuid())
  userId    String           // recipient
  user      User             @relation("UserNotifications", fields: [userId], references: [id])
  type      NotificationType
  actorId   String?          // who triggered it (not a FK — kept lightweight)
  metadata  Json?            // type-specific payload (matchId, itemKey, preview, …)
  read      Boolean          @default(false)
  readAt    DateTime?
  emailedAt DateTime?        // set once included in a delivered digest; never re-emailed
  createdAt DateTime         @default(now())

  // Drives the digest collection query (unread + un-emailed, grouped per user).
  @@index([userId, read, emailedAt])
  @@index([userId, createdAt])
}

// One row per digest email attempt for a user. Gives a delivery audit trail,
// retry bookkeeping (attempts/lastError), and dedup safety. FAILED rows are the
// retry queue; the notifications themselves stay un-emailed until a SENT row.
model EmailDigestLog {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation("UserEmailDigestLogs", fields: [userId], references: [id])
  status            EmailDeliveryStatus @default(PENDING)
  notificationCount Int                 @default(0)
  attempts          Int                 @default(0)
  lastError         String?
  providerMessageId String?             // e.g. Resend message id, for tracing
  sentAt            DateTime?
  createdAt         DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([status])
}

enum NotificationType {
  NEW_MESSAGE
  COLLAB_REQUEST
  PROJECT_INVITE
  NEW_MATCH
  PROFILE_INTERACTION
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}
