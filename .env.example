# Copy to ".env" on the server and fill in real values. Never commit the real .env.

# --- Database (Supabase Postgres) ---
# Pooled connection used by the app at runtime (PgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct (non-pooled) connection used ONLY for prisma migrate (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Supabase (OTP auth) ---
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."

# --- App auth ---
JWT_SECRET="a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Server ---
# Port the Nest app listens on (nginx proxies to this on 127.0.0.1).
PORT=8080
# Frontend origin allowed by CORS, e.g. https://app.crowhub.dating (no trailing slash).
WEB_ORIGIN="https://YOUR-FRONTEND-ORIGIN"

# --- Email digest (notifications) ---
# Resend API key. Without it, the digest job runs but every send fails (logged).
RESEND_API_KEY=""
# From address for digest emails (must be a verified Resend domain/sender).
MAIL_FROM="CrowHub <noreply@crowhub.dating>"
# Max in-call send retries (exponential backoff) before a send is marked failed.
MAIL_MAX_ATTEMPTS=3
# Where the "Open CrowHub" CTA points.
APP_WEB_URL="https://app.crowhub.dating"
# Master switch for the 6-hourly digest cron. Set to "false" to disable (e.g. dev).
DIGEST_ENABLED=true
# Don't email users active within this many minutes (they'll see it in-app).
DIGEST_ACTIVE_WINDOW_MINUTES=30
# Skip a user after this many FAILED digests in 24h (bad/bouncing address).
DIGEST_MAX_RETRIES=5
# Shared secret to manually trigger a digest via POST /digest/run
# (header: x-digest-secret). Leave empty to DISABLE the manual endpoint.
DIGEST_TRIGGER_SECRET=""
